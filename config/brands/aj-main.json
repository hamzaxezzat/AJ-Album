{
  "id": "aj-main",
  "name": "Al Jazeera Arabic",
  "logo": {
    "primary": {
      "id": "aj-logo-primary",
      "url": "/logos/aj-main/primary.svg",
      "mimeType": "image/svg+xml"
    },
    "reversed": {
      "id": "aj-logo-reversed",
      "url": "/logos/aj-main/reversed.svg",
      "mimeType": "image/svg+xml"
    },
    "compact": {
      "id": "aj-logo-compact",
      "url": "/logos/aj-main/compact.svg",
      "mimeType": "image/svg+xml"
    },
    "clearSpace": 0.03
  },
  "colors": {
    "locked": ["#D32F2F", "#B71C1C"],
    "palette": [
      { "hex": "#D32F2F", "label": "أحمر الجزيرة", "role": "primary-brand" },
      { "hex": "#1565C0", "label": "أزرق ثانوي", "role": "secondary" },
      { "hex": "#212121", "label": "أسود تحريري", "role": "dark" },
      { "hex": "#F5F5F5", "label": "أبيض دافئ", "role": "light" },
      { "hex": "#FFC107", "label": "ذهبي", "role": "accent-special" }
    ],
    "allowCustom": false
  },
  "bannerFamilies": [
    {
      "id": "classic-main",
      "name": "الكلاسيكي",
      "shape": "full-width",
      "borderRadius": 0,
      "sideAccentLine": false,
      "allowedPositions": ["top", "bottom", "float-top", "float-bottom"]
    },
    {
      "id": "accent-line",
      "name": "مع خط جانبي",
      "shape": "full-width",
      "borderRadius": 0,
      "sideAccentLine": true,
      "allowedPositions": ["top", "bottom", "float-top", "float-bottom", "none"]
    }
  ],
  "defaultBannerFamily": "classic-main",
  "footer": {
    "height": 0.074,
    "logoPosition": "right",
    "showSocialHandles": true,
    "socialHandles": [
      { "platform": "facebook", "handle": "aljazeerachannel" },
      { "platform": "youtube", "handle": "aljazeerachannel" },
      { "platform": "twitter", "handle": "ajarabic" }
    ],
    "paginationPosition": "left",
    "backgroundColor": "#FFFFFF",
    "textColor": "#212121"
  },
  "sourceStyle": {
    "position": "bottom-right",
    "sizeBreakpoints": [
      { "maxChars": 20, "scale": 1.0 },
      { "maxChars": 40, "scale": 0.85 },
      { "maxChars": 70, "scale": 0.70 },
      { "maxChars": 9999, "scale": 0.60 }
    ],
    "fontTokenRef": "body-s"
  },
  "typography": {
    "heading-xl": {
      "fontFamily": "Cairo, 'IBM Plex Arabic', sans-serif",
      "fontWeight": 700,
      "fontSize": 46,
      "lineHeight": 1.25,
      "letterSpacing": -0.02,
      "textAlign": "right",
      "direction": "rtl"
    },
    "heading-l": {
      "fontFamily": "Cairo, 'IBM Plex Arabic', sans-serif",
      "fontWeight": 700,
      "fontSize": 34,
      "lineHeight": 1.3,
      "letterSpacing": -0.01,
      "textAlign": "right",
      "direction": "rtl"
    },
    "heading-m": {
      "fontFamily": "'IBM Plex Arabic', Cairo, sans-serif",
      "fontWeight": 600,
      "fontSize": 26,
      "lineHeight": 1.35,
      "letterSpacing": 0,
      "textAlign": "right",
      "direction": "rtl"
    },
    "body-m": {
      "fontFamily": "'IBM Plex Arabic', sans-serif",
      "fontWeight": 400,
      "fontSize": 18,
      "lineHeight": 1.7,
      "letterSpacing": 0,
      "textAlign": "right",
      "direction": "rtl"
    },
    "body-s": {
      "fontFamily": "'IBM Plex Arabic', sans-serif",
      "fontWeight": 400,
      "fontSize": 14,
      "lineHeight": 1.5,
      "letterSpacing": 0,
      "textAlign": "right",
      "direction": "rtl"
    },
    "stat-display": {
      "fontFamily": "Cairo, sans-serif",
      "fontWeight": 700,
      "fontSize": 96,
      "lineHeight": 1.0,
      "letterSpacing": -0.03,
      "textAlign": "center",
      "direction": "ltr"
    },
    "label": {
      "fontFamily": "'IBM Plex Arabic', sans-serif",
      "fontWeight": 400,
      "fontSize": 12,
      "lineHeight": 1.4,
      "letterSpacing": 0.02,
      "textAlign": "right",
      "direction": "rtl"
    }
  },
  "availableArchetypes": [
    "standard_title_body",
    "bullet_list",
    "credentials_profile",
    "highlighted_statement",
    "data_card",
    "mixed_info"
  ],
  "defaultDensity": "normal",
  "brandLocks": {
    "locked": {
      "logoAsset": true,
      "logoClearSpace": true,
      "logoPosition": true,
      "footerStructure": true,
      "fontFamily": true,
      "brandColors": ["#D32F2F", "#B71C1C"]
    },
    "editable": {
      "accentColor": {
        "mode": "palette_only",
        "palette": ["#D32F2F", "#1565C0", "#212121"]
      },
      "bannerPosition": {
        "allowed": ["top", "bottom", "float-top", "float-bottom", "none"]
      },
      "bulletShape": {
        "allowed": ["square", "circle", "dash"]
      },
      "bulletDividers": true,
      "densityControl": true,
      "overlayOpacity": { "min": 0, "max": 0.5 },
      "sourceSize": { "minScale": 0.6, "maxScale": 1.0 }
    }
  },
  "allowedModes": ["production"],
  "numeralStyle": "western"
}
